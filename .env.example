# Gemini API Key (get from https://aistudio.google.com/apikey)
# Use a dedicated Gemini AI Studio project and API key for this app only.
# Never commit real secrets; keep production/test keys separate and rotate if exposed.
GEMINI_API_KEY=your_gemini_api_key_here
# Optional second key for failover / rotation across advisory calls
GEMINI_API_KEY_2=
# Optional alias if your team prefers an explicit secondary variable name
GEMINI_API_KEY_SECONDARY=
# Optional comma-separated pool; merged with the keys above if provided
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=8192

# Logging
LOG_LEVEL=INFO
DEBUG_MODE=false
